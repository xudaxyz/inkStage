<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inkstage.mapper.UserRoleMapper">

    <!-- 结果映射 -->
    <resultMap id="ResultMap" type="com.inkstage.entity.model.UserRole">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="roleId" column="role_id"/>
        <result property="assignedBy" column="assigned_by"/>
        <result property="assignedAt" column="assigned_at"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="status" column="status" javaType="com.inkstage.enums.StatusEnum"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- 新增用户角色关联 -->
    <insert id="insert" parameterType="com.inkstage.entity.model.UserRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_role (
        user_id, role_id, assigned_by, assigned_at, expires_at, status, create_time, update_time, deleted
        ) VALUES (
        #{userId}, #{roleId}, #{assignedBy}, #{assignedAt}, #{expiresAt}, #{status}, #{createTime}, #{updateTime},
        #{deleted}
        )
    </insert>

    <!-- 根据用户ID查询角色列表 -->
    <select id="selectByUserId" parameterType="java.lang.Long" resultMap="ResultMap">
        SELECT * FROM user_role
        WHERE user_id = #{userId}
        AND deleted = 0
        AND status = 1
    </select>

    <!-- 根据用户ID删除角色关联 -->
    <delete id="deleteByUserId" parameterType="java.lang.Long">
        DELETE FROM user_role
        WHERE user_id = #{userId}
    </delete>

    <update id="updateUserRole">
        UPDATE user_role
        SET role_id = #{userRole}, update_time = now()
        WHERE user_id = #{userId}
    </update>
</mapper>