<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.inkstage.mapper.TagMapper">
    <!-- 基础结果映射 -->
    <resultMap id="ResultMap" type="com.inkstage.entity.model.Tag">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="slug" property="slug" />
        <result column="description" property="description" />
        <result column="article_count" property="articleCount" />
        <result column="usage_count" property="usageCount" />
        <result column="status" property="status" javaType="com.inkstage.enums.StatusEnum" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" javaType="com.inkstage.enums.DeleteStatus" />
        <result column="deleted_time" property="deletedTime" />
    </resultMap>

    <sql id="baseColumns">
        id, name, slug, description, article_count, usage_count, status, create_time, update_time, deleted, deleted_time
    </sql>

    <!-- 获取所有标签 -->
    <select id="selectAll" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM tag
        ORDER BY id ASC
    </select>

    <!-- 分页获取标签 -->
    <select id="selectByKeyword" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM tag
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%') OR slug LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id ASC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 统计标签总数 -->
    <select id="countByKeyword" resultType="java.lang.Long">
        SELECT COUNT(*) FROM tag
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%') OR slug LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <!-- 根据ID获取标签 -->
    <select id="selectById" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM tag
        WHERE id = #{id}
    </select>

    <!-- 获取所有激活状态的标签 -->
    <select id="selectActiveTags" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM tag
        WHERE status = 1
        ORDER BY id ASC
    </select>

    <!-- 根据文章ID获取标签 -->
    <select id="selectByArticleId" resultMap="ResultMap">
        SELECT t.<include refid="baseColumns" />
        FROM tag t
        JOIN article_tag at ON t.id = at.tag_id
        WHERE at.article_id = #{articleId}
        ORDER BY t.id ASC
    </select>

    <!-- 插入文章标签关联 -->
    <insert id="insertArticleTag" parameterType="com.inkstage.entity.model.ArticleTag">
        INSERT INTO article_tag (article_id, tag_id)
        VALUES (#{articleId}, #{tagId})
    </insert>

    <!-- 删除文章的标签关联 -->
    <delete id="deleteArticleTagsByArticleId" parameterType="java.lang.Long">
        DELETE FROM article_tag WHERE article_id = #{articleId}
    </delete>

    <!-- 插入标签 -->
    <insert id="insert" parameterType="com.inkstage.entity.model.Tag">
        INSERT INTO tag (
            name, slug, description, article_count, usage_count, status
        ) VALUES (
            #{name}, #{slug}, #{description}, #{articleCount}, #{usageCount}, #{status}
        )
    </insert>

    <!-- 更新标签 -->
    <update id="update" parameterType="com.inkstage.entity.model.Tag">
        UPDATE tag SET
            name = #{name},
            slug = #{slug},
            description = #{description},
            status = #{status}
        WHERE id = #{id}
    </update>

    <!-- 根据ID删除标签 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM tag WHERE id = #{id}
    </delete>

    <!-- 更新标签状态 -->
    <update id="updateStatus">
        UPDATE tag SET
            status = #{status}
        WHERE id = #{id}
    </update>

</mapper>
