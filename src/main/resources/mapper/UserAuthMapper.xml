<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inkstage.mapper.UserAuthMapper">
    
    <!-- 结果映射 -->
    <resultMap id="ResultMap" type="com.inkstage.entity.model.UserAuth">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="authType" column="auth_type" />
        <result property="authIdentifier" column="auth_identifier" />
        <result property="authCredential" column="auth_credential" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="deleted" column="deleted" />
    </resultMap>
    
    <!-- 新增用户认证 -->
    <insert id="insert" parameterType="com.inkstage.entity.model.UserAuth" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_auth (
            user_id, auth_type, auth_identifier, auth_credential, 
            create_time, update_time, deleted
        ) VALUES (
            #{userId}, #{authType}, #{authIdentifier}, #{authCredential}, 
            #{createTime}, #{updateTime}, #{deleted}
        )
    </insert>
</mapper>