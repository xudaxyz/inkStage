<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inkstage.mapper.UserAuthMapper">

    <!-- 结果映射 -->
    <resultMap id="ResultMap" type="com.inkstage.entity.model.UserAuth">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="auth_type" property="authType"/>
        <result column="auth_identifier" property="authIdentifier"/>
        <result column="auth_credential" property="authCredential"/>
        <result column="primary_auth" property="primaryAuth" javaType="com.inkstage.enums.DefaultStatus"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted" javaType="com.inkstage.enums.DeleteStatus"/>
    </resultMap>

    <!-- 新增用户认证 -->
    <insert id="insert" parameterType="com.inkstage.entity.model.UserAuth" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_auth (
        user_id, auth_type, auth_identifier, auth_credential,
        create_time, update_time, deleted
        ) VALUES (
        #{userId}, #{authType}, #{authIdentifier}, #{authCredential},
        #{createTime}, #{updateTime}, #{deleted}
        )
    </insert>

    <!-- 根据用户ID和认证类型查询认证信息 -->
    <select id="findByUserIdAndType" resultMap="ResultMap">
        SELECT * FROM user_auth
        WHERE user_id = #{userId} AND auth_type = #{authType} AND deleted = 0
    </select>

    <!-- 根据用户ID查询所有认证信息 -->
    <select id="findByUserId" resultMap="ResultMap">
        SELECT * FROM user_auth
        WHERE user_id = #{userId} AND deleted = 0
    </select>

    <!-- 根据认证标识和类型查询认证信息 -->
    <select id="findByIdentifierAndType" resultMap="ResultMap">
        SELECT * FROM user_auth
        WHERE auth_identifier = #{identifier} AND auth_type = #{authType} AND deleted = 0
    </select>

    <!-- 更新用户认证信息 -->
    <update id="update" parameterType="com.inkstage.entity.model.UserAuth">
        UPDATE user_auth
        SET
            auth_identifier = #{authIdentifier},
            auth_credential = #{authCredential},
            primary_auth = #{primaryAuth},
            update_time = #{updateTime}
        WHERE
            id = #{id}
            AND deleted = 0
    </update>

    <!-- 删除用户认证信息 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM user_auth
        WHERE id = #{id}
    </delete>

    <!-- 根据用户ID删除所有认证信息 -->
    <delete id="deleteByUserId" parameterType="java.lang.Long">
        DELETE FROM user_auth
        WHERE user_id = #{userId}
    </delete>
</mapper>