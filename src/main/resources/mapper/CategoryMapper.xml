<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.inkstage.mapper.CategoryMapper">
    <!-- 基础结果映射 -->
    <resultMap id="ResultMap" type="com.inkstage.entity.model.Category">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="slug" property="slug" />
        <result column="parent_id" property="parentId" />
        <result column="sort_order" property="sortOrder" />
        <result column="description" property="description" />
        <result column="article_count" property="articleCount" />
        <result column="status" property="status" javaType="com.inkstage.enums.common.StatusEnum" />
        <result column="category_version" property="categoryVersion" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" javaType="com.inkstage.enums.common.DeleteStatus" />
        <result column="deleted_time" property="deletedTime" />
    </resultMap>

    <sql id="baseColumns">
        id, name, slug, parent_id, sort_order, description, article_count, status, category_version, create_time, update_time, deleted, deleted_time
    </sql>

    <!-- 获取所有分类 -->
    <select id="findAll" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM category
        ORDER BY sort_order ASC, id ASC
    </select>

    <!-- 分页获取分类 -->
    <select id="findByKeyword" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM category
        <where>
            <if test="keyword != null">
                name LIKE CONCAT('%', #{keyword}, '%') OR slug LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY article_count DESC, sort_order ASC, id ASC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 统计分类总数 -->
    <select id="countByKeyword" resultType="java.lang.Long">
        SELECT COUNT(*) FROM category
        <where>
            <if test="keyword != null">
                name LIKE CONCAT('%', #{keyword}, '%') OR slug LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <!-- 根据ID获取分类 -->
    <select id="findById" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM category
        WHERE id = #{id}
    </select>

    <!-- 获取所有激活状态的分类 -->
    <select id="findActiveCategories" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM category
        WHERE status = 1
        ORDER BY article_count DESC, sort_order ASC, id ASC
    </select>

    <!-- 添加分类 -->
    <insert id="insert" parameterType="com.inkstage.entity.model.Category">
        INSERT INTO category (
            name, slug, parent_id, sort_order, description, article_count, status, category_version
        ) VALUES (
            #{name}, #{slug}, #{parentId}, #{sortOrder}, #{description}, #{articleCount}, #{status}, #{categoryVersion}
        )
    </insert>

    <!-- 更新分类 -->
    <update id="update" parameterType="com.inkstage.entity.model.Category">
        UPDATE category
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="slug != null">
                slug = #{slug},
            </if>
            <if test="parentId != null">
                parent_id = #{parentId},
            </if>
            <if test="sortOrder != null">
                sort_order = #{sortOrder},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="categoryVersion != null">
                category_version = #{categoryVersion},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime}
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除分类 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM category WHERE id = #{id}
    </delete>

    <!-- 更新分类状态 -->
    <update id="updateStatus">
        UPDATE category SET
            status = #{status}
        WHERE id = #{id}
    </update>

    <!-- 批量查询分类 -->
    <select id="findByIds" parameterType="java.util.List" resultMap="ResultMap">
        SELECT <include refid="baseColumns" /> FROM category
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 更新分类文章数量 -->
    <update id="updateArticleCount">
        UPDATE category SET
            article_count = article_count + #{increment}
        WHERE id = #{categoryId}
    </update>

    <!-- 根据分类ID查询分类版本号 -->
    <select id="findCategoryVersionById" resultType="java.lang.Integer">
        SELECT category_version FROM category WHERE id = #{id}
    </select>

</mapper>
